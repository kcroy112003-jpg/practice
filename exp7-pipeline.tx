pipeline {
agent any
stages {
stage('Checkout') {
steps {
git branch: 'main', url: 'https://github.com/&lt;user&gt;/&lt;repo&gt;.git'
}
}
stage('Build') {
steps { sh 'mvn clean package' }
}
stage('Test') {
steps { sh 'mvn test' }
}
}
post {
always { junit '**/target/surefire-reports/*.xml' }
success { echo 'Build and tests succeeded!' }
failure { echo 'Build or tests failed.' }
}
}
